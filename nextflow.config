params {
    // Input
    input             = null          // samplesheet CSV
    fastq_dir         = null          // alternativa: directorio con FASTQs
    reference         = null          // genoma de referencia .fa
    genome            = "hg38"        // opciones: hg38, t2t

    // Parámetros del pipeline
    min_read_support  = 3
    threads           = 32
    species           = "homo_sapiens"
    callers           = "cuteSV,sniffles2"
    mode              = "full"        // full o light (sin anotación, para T2T)

    // Distancias de merging
    dist_intra        = 60
    dist_inter        = 60
    survivor_intra    = 60
    survivor_inter    = 100

    // Output
    outdir            = "results"
    all_prefix        = "all"
    keep_rds          = true
    enrichment_pval   = 0.05

    // Datasets de comparación
    datasets          = []
    comparisons       = []
}

// Perfiles de ejecución
profiles {
    dayhoff {
        process.executor       = 'slurm'
        process.queue          = 'eck-q'
        process.clusterOptions = '--time=24:00:00'
        conda.enabled          = true
        conda.useMamba         = false
    }
    local {
        process.executor = 'local'
        conda.enabled    = true
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// Configuración por defecto de procesos
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withName: 'MINIMAP2_ALIGN' {
        cpus   = params.threads
        memory = '32 GB'
        time   = '8 h'
    }
    withName: 'CUTESV' {
        cpus   = params.threads
        memory = '16 GB'
    }
    withName: 'SNIFFLES2' {
        cpus   = params.threads
        memory = '16 GB'
    }
    withName: 'REPEATMASKER' {
        cpus   = 16
        memory = '32 GB'
        time   = '4 h'
    }
    withName: 'R_.*' {
        cpus   = 16
        memory = '32 GB'
    }
}
