
cleanup = true   


// Pipeline parameters

params {
    // Input
    input             = null          // samplesheet CSV
    fastq_dir         = null          // alternative: dir with FASTQs
    reference         = null          // reference genome .fa (optional)
    genome            = null          // options: hg38, t2t

    // Pipeline behaviour
    min_read_support  = 3
    threads           = 32
    species           = "homo_sapiens"
    callers           = "cuteSV,sniffles2"
    mode              = null          // full | light (light = no annotation)

    // SV merging distances
    dist_intra        = 60
    dist_inter        = 60
    survivor_intra    = 60
    survivor_inter    = 100

    // Output
    outdir            = "results"
    all_prefix        = "all"
    keep_rds          = true
    enrichment_pval   = 0.05

    // Dataset comparisons
    datasets          = []
    comparisons       = [["HG00514", "NA19240"]]
}

// Execution profiles

profiles {

    // Compute environment: dayhoff SLURM cluster
    dayhoff {
        process.executor       = 'slurm'
        process.queue          = 'eck-q'
        process.clusterOptions = '--time=24:00:00'
        workDir                = "${projectDir}/work_dayhoff"
    }

    // Compute environment: local execution (laptop tests)
    local {
        process.executor = 'local'
    }

    // Runtime: conda envs from yamls (kept for backward compatibility)
    conda {
        conda.enabled    = true
        conda.useMamba   = true
        conda.mambaPath  = '/home/alumno27/miniforge3/bin/mamba'
        conda.cacheDir   = "${projectDir}/.conda_envs"
        docker.enabled   = false
    }

    // Runtime: Docker (used on dayhoff and the tutor's cluster)
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled     = false

        process {
            container = 'monicazh/retroinspector-nf:0.1.0'
        }
    }
}


// Per-process env activation (Docker runtime only)
//
// The Docker image is based on mambaorg/micromamba and ships four isolated
// environments (retro-base, retro-sniffles2, retro-rm-t2t, retro-r).
// Activation uses micromamba (not conda), because the image does not include
// conda's profile.d activation scripts. `micromamba shell hook --shell bash`
// generates the equivalent shell setup; `eval` injects it into the current
// shell. After that, `micromamba activate ENV` works exactly like
// `conda activate ENV` (sets PATH, CONDA_PREFIX, R_LIBS_USER, etc.).
//
// These beforeScripts are no-ops when running with -profile conda (no
// container, no micromamba on the host), and active when running with
// -profile docker.


process {
    errorStrategy   = 'retry'
    maxRetries      = 2
    containerOptions = '-e NXF_ENV=retro-base'

    withName: 'MINIMAP2_ALIGN' {
        cpus   = 16
        memory = '48 GB'
    }

    withName: 'CUTESV' {
        cpus   = 8
        memory = '16 GB'
    }

    withName: 'SNIFFLES2' {
        cpus             = 8
        memory           = '16 GB'
        containerOptions = '-e NXF_ENV=retro-sniffles2'
    }

    withName: 'R_.*' {
        cpus             = 2
        memory           = '16 GB'
        containerOptions = '-e NXF_ENV=retro-r'
    }

    withName: 'REPEATMASKER' {
        cpus             = 16
        memory           = '32 GB'
        containerOptions = { params.genome == 't2t'
            ? '-e NXF_ENV=retro-rm-t2t'
            : '-e NXF_ENV=retro-base'
        }
    }

    withName: 'GET_REPEATMASKER_LIB_T2T' {
        containerOptions = '-e NXF_ENV=retro-rm-t2t'
    }
}


// Execution traces 


timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
