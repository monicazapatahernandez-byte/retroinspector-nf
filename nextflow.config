cleanup = true



params {
    // Input
    input             = null          // samplesheet CSV
    fastq_dir         = null          // alternativa: directorio con FASTQs
    reference         = null          // genoma de referencia .fa
    genome            = null         // opciones: hg38, t2t

    // Parámetros del pipeline
    min_read_support  = 3
    threads           = 32
    species           = "homo_sapiens"
    callers           = "cuteSV,sniffles2"
    mode              = null        // full o light (sin anotación, para T2T)

    // Distancias de merging
    dist_intra        = 60
    dist_inter        = 60
    survivor_intra    = 60
    survivor_inter    = 100

    // Output
    outdir            = "results"
    all_prefix        = "all"
    keep_rds          = true
    enrichment_pval   = 0.05

    // Datasets de comparación
    datasets          = []
    comparisons       = [["HG00514", "NA19240"]]
}

// Perfiles de ejecución
profiles {
    dayhoff {
        process.executor       = 'slurm'
        process.queue          = 'eck-q'
        process.clusterOptions = '--time=24:00:00'
        conda.enabled          = true
        conda.useMamba         = true
        conda.mambaPath        = '/home/alumno27/miniforge3/bin/mamba' 
        conda.cacheDir         = "${projectDir}/.conda_envs"
    }



    docker {
        conda.enabled = false

        docker {
            enabled = true
            runOptions = '-u $(id -u):$(id -g)'
        }

        process {
            container = 'retroinspector-nf:latest'

            withName: 'SNIFFLES2' {
                beforeScript = 'export PATH=/opt/conda/envs/retro-sniffles2/bin:$PATH'
            }

            withName: 'GET_REPEATMASKER_LIB_T2T|REPEATMASKER' {
                beforeScript = 'export PATH=/opt/conda/envs/retro-rm-t2t/bin:$PATH; export CONDA_PREFIX=/opt/conda/envs/retro-rm-t2t'
            }

            withName: 'R_PREPARATORY|R_GENOTYPING|R_ENRICHMENT|R_REPORT|R_COMPARE|GENERATE_VCF' {
                beforeScript = 'export PATH=/opt/conda/envs/retro-r/bin:$PATH'
            }
        }
    }








    local {
        process.executor = 'local'
        conda.enabled    = true
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// Configuración por defecto de procesos

process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withName: 'MINIMAP2_ALIGN' { cpus = 16; memory = '48 GB' }
    withName: 'CUTESV'         { cpus = 8;  memory = '16 GB' }
    withName: 'SNIFFLES2'      { cpus = 8;  memory = '16 GB' }
    withName: 'REPEATMASKER'   { cpus = 16; memory = '32 GB' }
    withName: 'R_.*'           { cpus = 2;  memory = '16 GB' }
}
